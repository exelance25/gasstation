# Test cüzdanları — SADECE adresler (private key ASLA bu dosyaya yazmayın)
# Gerçek anahtarları yalnızca yerel, gitignore'lu dosyada tutun veya hiç dosyaya yazmayın.
# Kopyala: .env.test.local (gitignore'da)

TEST_SEPOLIA_DEPOSITOR=0xYourSepoliaDepositorAddress
TEST_SEPOLIA_TARGET=0xYourSepoliaTargetAddress
TEST_SOLANA_DEPOSITOR=YourSolanaDepositorBase58Address
TEST_SOLANA_TARGET=YourSolanaTargetBase58Address

# İsteğe bağlı — otomatik E2E için (sadece testnet, asla mainnet anahtarı kullanmayın)
# TEST_SEPOLIA_DEPOSITOR_PK=0x...
# TEST_SOLANA_DEPOSITOR_PK=base58_secret_key
