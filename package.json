{
  "name": "gas-pump-widget",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "dev:clean": "node scripts/dev-clean-start.mjs",
    "start:dev": "node scripts/dev-clean-start.mjs",
    "clean": "node scripts/dev-reset.mjs",
    "build": "node scripts/run-next.mjs build",
    "start": "node scripts/run-next.mjs start",
    "lint": "next lint",
    "test:integration": "node scripts/run-next.mjs exec tsx test-integration.ts",
    "test:oracle-fallback": "node scripts/run-next.mjs exec tsx scripts/verify-oracle-fallback.mjs",
    "test:dispense-api": "node scripts/test-dispense-api.mjs",
    "test:workflow": "node scripts/test-workflow-report.mjs",
    "test:testnet-full": "node scripts/testnet-full-run.mjs",
    "test:solana-e2e": "node scripts/quick-testnet.mjs",
    "test:quick": "node scripts/quick-testnet.mjs",
    "test:vault-sol": "node scripts/try-vault-sol-dispense.mjs",
    "test:fund-depositors": "node scripts/fund-testnet-depositors.mjs",
    "test:dispense-mon": "node scripts/test-dispense-mon.mjs",
    "test:e2e-dispense": "node scripts/test-e2e-dispense.mjs",
    "preflight": "node scripts/preflight-mainnet.mjs",
    "check:treasury": "node scripts/check-treasury.mjs",
    "security:audit": "node scripts/security-audit.mjs",
    "test:sdk": "npm run build:sdk && tsx sdk/examples/smoke-test.ts",
    "build:sdk": "cd sdk && npm install && npm run build",
    "test:contracts": "cd contracts && forge test -vvv",
    "deploy:testnet": "powershell -ExecutionPolicy Bypass -File scripts/deploy-testnet.ps1",
    "marketplace:install": "cd services/marketplace && npm install",
    "marketplace:dev": "cd services/marketplace && npm run dev",
    "marketplace:migrate": "cd services/marketplace && npm run migrate",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "go": "cmd /c GO.cmd",
    "marketplace": "cmd /c START_MARKETPLACE.cmd",
    "quote-engine:install": "cd services/quote-engine && npm install",
    "quote-engine:dev": "cd services/quote-engine && npm run dev",
    "fee-sdk:smoke": "cd packages/fee-sdk && npm install && tsx examples/smoke.ts",
    "settlement:install": "cd services/settlement-engine && npm install",
    "settlement:dev": "cd services/settlement-engine && npm run dev",
    "stack:dev": "cmd /c START_STACK.cmd",
    "stack:full": "cmd /c START_FULL_STACK.cmd",
    "stack:lite": "cmd /c START_QUOTE_LITE.cmd",
    "preflight:stack": "node scripts/preflight-stack.mjs",
    "test:stack-auto-fee": "node scripts/test-stack-auto-fee.mjs",
    "test:matrix": "node scripts/test-requested-matrix.mjs",
    "test:modes": "node scripts/test-ui-modes.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
