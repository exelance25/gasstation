# === PUMPSTATION Testnet (.env.local olarak kopyalayin) ===
NEXT_PUBLIC_APP_ENV=testnet
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_AUTO_FEE_ENABLED=true
NEXT_PUBLIC_WC_PROJECT_ID=replace_wallet_connect_key

# RPC
NEXT_PUBLIC_ETH_MAINNET_RPC=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Kontratlar (deploy-testnet.ps1 sonrasi doldurun)
# NEXT_PUBLIC_PUMP_PAYMASTER_ADDRESS=0x...
NEXT_PUBLIC_ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
NEXT_PUBLIC_MONAD_USDC_ADDRESS=0x534b2f3A21130d7a60830c2Df862319e593943A3
NEXT_PUBLIC_MONAD_MAINNET_RPC=https://rpc.monad.xyz

# E2E test (opsiyonel)
# TEST_GAS_RECIPIENT=0x...
# TEST_DEPOSITOR_PRIVATE_KEY=0x...
# DEPOSIT_TX_HASH=0x...

# Sunucu-only (asla NEXT_PUBLIC yapmayin)
# ADMIN_WALLET_ADDRESS=0x...
# DEPLOYER_PRIVATE_KEY=0x...
# PRICE_SIGNER_ADDRESS=0x...
# BASE_RPC_PRIVATE_URL=https://sepolia.base.org
# RELAYER_PRIVATE_KEY=0x...
