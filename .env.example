# Client-safe (NEXT_PUBLIC_* only — never put secrets here)
# development | testnet | staging | mainnet
NEXT_PUBLIC_APP_ENV=development
# GitHub repo — SDK panel linkleri (push sonrası doldurun)
# NEXT_PUBLIC_GITHUB_REPO=https://github.com/exelance25/gasstation
# Passwordless dev login on welcome/login (set false to disable)
NEXT_PUBLIC_QUICK_LOGIN=true
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_MARKETPLACE_API_URL=http://localhost:4000
QUOTE_ENGINE_URL=http://localhost:4100
SETTLEMENT_ENGINE_URL=http://localhost:4200
# SETTLEMENT_API_KEY=
# NEXT_PUBLIC_FEE_SDK_API_URL=http://localhost:3000/api
NEXT_PUBLIC_WC_PROJECT_ID=replace_wallet_connect_key
# WalletConnect — yalnızca gerçek Reown projesi ile açın:
# NEXT_PUBLIC_WC_ENABLED=true
# https://cloud.reown.com → Project → Domains → http://localhost:3000
NEXT_PUBLIC_ETH_MAINNET_RPC=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_ETH_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com
NEXT_PUBLIC_SOLANA_DEVNET_RPC=https://api.devnet.solana.com

# Testnet sablonu: .env.testnet.example dosyasini .env.local olarak kopyalayin
# PumpPaymaster / USDC toplama kasası (deploy sonrası doldurun)
# NEXT_PUBLIC_PUMP_TREASURY_ADDRESS=0x...
# NEXT_PUBLIC_PUMP_PAYMASTER_ADDRESS=0x...
# NEXT_PUBLIC_ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# NEXT_PUBLIC_BASE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# NEXT_PUBLIC_BASE_USDT_ADDRESS=0x...    (opsiyonel)
# EVM USDC depozit kasası (sadece public ADRES — key asla buraya değil)
# NEXT_PUBLIC_COLLECTOR_ADDRESS=0x...
# COLLECTOR_ADDRESS=0x...

# Gas teslimat operatörü — ETH / BASE / MON (SUNUCU-ONLY, .env.local)
# EVM_OPERATOR_PRIVATE_KEY=0x...
# SOLANA_PRIVATE_KEY=base58_or_json_array
# SOLANA_COLLECTOR_ADDRESS=...   (opsiyonel referans)
# Server-only (no NEXT_PUBLIC prefix) — copy to .env.local for local dev
# Gas Havuzu — asla NEXT_PUBLIC yapmayın; tarayıcı bundle'ına girer
# ADMIN_WALLET_ADDRESS=0x...
# SESSION_ENCRYPTION_KEY=generate_32_byte_hex_key
# API_SECRET_KEY=server_only_secret
# WALLETCONNECT_SECRET=server_only_wc_secret
# BASE_RPC_PRIVATE_URL=https://sepolia.base.org
# ETH_RPC_PRIVATE_URL=https://your-private-rpc.example
# Relayer — ERC-4337 (sunucu-only)
# RELAYER_PRIVATE_KEY=0x...
# RELAYER_API_KEY=generate_strong_key_for_relay_endpoints
# PRICE_SIGNER_PRIVATE_KEY=0x...  (paymaster quote imzası — relayer ile aynı olabilir)
# ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# Contact & feedback (Vercel — pick at least one)
# BLOB_READ_WRITE_TOKEN=   (Storage → Blob in Vercel dashboard; recommended)
# FEEDBACK_NOTIFY_EMAIL=your@email.com   (instant email via formsubmit — no Blob required)
# FEEDBACK_WEBHOOK_URL=    (optional Discord/Slack webhook)
