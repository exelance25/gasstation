{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@config/*": ["./config/*"],
      "@gasstation/sdk": ["./sdk/src/index.ts"],
      "@gasstation/gas-engine": ["./packages/gas-engine-stub/index.ts"],
      "@gasstation/fee-sdk": ["./packages/fee-sdk/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "config/**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "sdk", "packages", "services", "contracts", "test-integration.ts"]
}
