# === GASSTATION Mainnet (.env.production veya deploy secret store) ===
NEXT_PUBLIC_APP_ENV=mainnet
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api
NEXT_PUBLIC_QUICK_LOGIN=false

# WalletConnect — gerçek 32-char project id (zorunlu)
NEXT_PUBLIC_WC_PROJECT_ID=replace_with_real_walletconnect_project_id

# Public RPC (üretimde private RPC önerilir)
NEXT_PUBLIC_ETH_MAINNET_RPC=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
NEXT_PUBLIC_MONAD_MAINNET_RPC=https://rpc.monad.xyz
NEXT_PUBLIC_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com

# USDC depozit kasası (sadece adres — key asla NEXT_PUBLIC yapmayın)
NEXT_PUBLIC_COLLECTOR_ADDRESS=0x...
COLLECTOR_ADDRESS=0x...

# Solana collector
NEXT_PUBLIC_SOLANA_VAULT_ADDRESS=
SOLANA_COLLECTOR_ADDRESS=

# Opsiyonel USDC override
# NEXT_PUBLIC_MONAD_USDC_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603

# ERC-4337 (opsiyonel — deploy sonrası)
# NEXT_PUBLIC_PUMP_PAYMASTER_ADDRESS=0x...
NEXT_PUBLIC_ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# === SUNUCU-ONLY (asla client bundle / git) ===
EVM_OPERATOR_PRIVATE_KEY=0x...
SOLANA_PRIVATE_KEY=

# Private RPC (önerilir)
ETH_RPC_PRIVATE_URL=
BASE_RPC_PRIVATE_URL=
MONAD_RPC_PRIVATE_URL=
SOLANA_RPC_PRIVATE_URL=

# Güvenlik
SESSION_ENCRYPTION_KEY=
API_SECRET_KEY=
ADMIN_WALLET_ADDRESS=0x...

# Kalıcı double-spend koruması (production)
# DISPENSE_IDEMPOTENCY_FILE=/var/lib/gasstation/dispense-processed.json
