# PUMPSTATION Marketplace API
MARKETPLACE_PORT=4000
DATABASE_URL=postgresql://pumpstation:pumpstation_dev@localhost:5432/pumpstation_marketplace
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:3000
APP_ENV=development
ORDER_EXPIRY_MINUTES=30
# Katman A — Quote Engine
QUOTE_ENGINE_URL=http://localhost:4100

# Katman B — Settlement (opsiyonel — fulfillment bridge)
SETTLEMENT_ENGINE_URL=http://localhost:4200

ORACLE_API_URL=http://localhost:3000/api/oracle/quote

# HD deposit addresses (production: use real mnemonic — NEVER commit)
# DEPOSIT_MASTER_MNEMONIC=

# Treasury delivery keys (server-only)
# EVM_OPERATOR_PRIVATE_KEY=
# SOLANA_PRIVATE_KEY=

# Admin panel API
# ADMIN_API_KEY=your_secret_admin_key

# RPC overrides
# ETH_RPC_URL=
# BASE_RPC_URL=
# MONAD_RPC_URL=
# SOLANA_RPC_URL=
